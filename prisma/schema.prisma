// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                 @id @default(uuid())
  fullName                 String
  userName                 String?                @unique
  instagram                String?
  password                 String?
  email                    String?
  role                     UserRole               @default(USER)
  phone                    String                 @unique
  createdAt                DateTime
  updatedAt                DateTime?
  isVerified               Boolean                @default(false)
  verificationCode         VerificationCode[]
  lastPasswordModification DateTime?
  isEmailVerified          Boolean?
  predictions              Prediction[]
  PredictionLastPlayer     PredictionLastPlayer[]

  @@map("users")
}

model VerificationCode {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  code      String
  expireIn  DateTime
  createdAt DateTime
  updatedAt DateTime?

  @@map("verification_codes")
}

model Championship {
  id        String             @id @default(uuid())
  name      String             @unique
  status    ChampionshipStatus @default(WAITING)
  createdAt DateTime
  updatedAt DateTime?
  rounds    Round[]
}

model Round {
  id                   String                 @id @default(uuid())
  name                 String
  status               RoundStatus            @default(WAITING)
  createdAt            DateTime
  updatedAt            DateTime?
  matchs               Match[]
  championship         Championship           @relation(fields: [championshipId], references: [id])
  championshipId       String
  Player               Player[]
  PredictionLastPlayer PredictionLastPlayer[]
}

model Team {
  id                   String                 @id @default(uuid())
  name                 String                 @unique
  createdAt            DateTime
  updatedAt            DateTime?
  matchsHome           Match[]                @relation("teamHome")
  matchsAway           Match[]                @relation("teamAway")
  status               TeamStatus             @default(ACTIVE)
  Player               Player[]
  PredictionLastPlayer PredictionLastPlayer[]
}

model Player {
  id                   String                 @id @default(uuid())
  name                 String
  team                 Team                   @relation(fields: [teamId], references: [id])
  teamId               String
  round                Round                  @relation(fields: [roundId], references: [id])
  roundId              String
  createdAt            DateTime
  updatedAt            DateTime?
  status               PlayerStatus
  predictionLastPlayer PredictionLastPlayer[]
  Prediction           Prediction[]
  Match                Match[]
}

model Prediction {
  id             String         @id @default(uuid())
  predictionHome Int?
  predictionAway Int?
  user           User           @relation(fields: [userId], references: [id])
  userId         String
  match          Match          @relation(fields: [matchId], references: [id])
  matchId        String
  predictionType PredictionType
  lastPlayer     Player?        @relation(fields: [lastPlayerId], references: [id])
  lastPlayerId   String?
  createdAt      DateTime
  updatedAt      DateTime?
}

model PredictionLastPlayer {
  id        String                     @id @default(uuid())
  player    Player                     @relation(fields: [playerId], references: [id])
  playerId  String
  user      User                       @relation(fields: [userId], references: [id])
  userId    String
  round     Round                      @relation(fields: [roundId], references: [id])
  roundId   String
  team      Team                       @relation(fields: [teamId], references: [id])
  teamId    String
  createdAt DateTime
  updatedAt DateTime?
  status    PredictionLastPlayerStatus
}

model Match {
  id           String       @id @default(uuid())
  scoreHome    Int
  scoreAway    Int
  teamHome     Team         @relation("teamHome", fields: [teamIdHome], references: [id])
  teamIdHome   String
  teamAway     Team         @relation("teamAway", fields: [teamIdAway], references: [id])
  teamIdAway   String
  round        Round        @relation(fields: [roundId], references: [id])
  roundId      String
  status       MatchStatus  @default(WAITING)
  date         DateTime
  createdAt    DateTime
  updatedAt    DateTime?
  lastPlayer   Player?      @relation(fields: [lastPlayerId], references: [id])
  lastPlayerId String?
  predictions  Prediction[]

  @@unique([teamIdHome, teamIdAway, date], name: "unique_team_match_date")
}

enum MatchStatus {
  WAITING
  IN_PROGRESS
  DONE
  CANCELED
  INACTIVE
}

enum ChampionshipStatus {
  WAITING
  IN_PROGRESS
  DONE
  CANCELED
  INACTIVE
}

enum RoundStatus {
  WAITING
  IN_PROGRESS
  DONE
  CANCELED
  INACTIVE
}

enum UserRole {
  ADMIN
  USER
}

enum TeamStatus {
  ACTIVE
  INACTIVE
}

enum PlayerStatus {
  ACTIVE
  INACTIVE
}

enum PredictionLastPlayerStatus {
  ACTIVE
  INACTIVE
}

enum PredictionType {
  SCORE
  PLAYER
}
